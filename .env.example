# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_dev_password
POSTGRES_DB=attendance_tracker
DATABASE_URL=postgresql://postgres:postgres_dev_password@localhost:5432/attendance_tracker

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_super_secret_jwt_key_min_64_chars_long_replace_in_production
JWT_REFRESH_SECRET=change_me_refresh_secret_key_min_64_chars_long_replace_in_production

# ── Service Ports ─────────────────────────────────────────────────────────────
WEB_PORT=3000
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
ATTENDANCE_SERVICE_PORT=3003
SCHEDULE_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005

# ── Service URLs (Docker internal) ───────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
ATTENDANCE_SERVICE_URL=http://localhost:3003
SCHEDULE_SERVICE_URL=http://localhost:3004
NOTIFICATION_SERVICE_URL=http://localhost:3005

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_ATTENDANCE_SERVICE_URL=http://localhost:3003
