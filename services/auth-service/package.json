{
  "name": "@attendance-tracker/auth-service",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run --coverage",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "db:studio": "prisma studio --schema=prisma/schema.prisma",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@attendance-tracker/shared-types": "workspace:*",
    "@attendance-tracker/config": "workspace:*",
    "@attendance-tracker/utils": "workspace:*",
    "@prisma/client": "7.8.0",
    "@prisma/adapter-pg": "7.8.0",
    "pg": "8.20.0",
    "express": "5.2.1",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "jsonwebtoken": "9.0.3",
    "bcryptjs": "3.0.3",
    "zod": "4.3.6",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "25.6.0",
    "typescript": "6.0.3",
    "tsx": "^4.19.4",
    "vitest": "^3.2.0",
    "@vitest/coverage-v8": "^3.2.0",
    "prisma": "7.8.0",
    "@types/pg": "^8.11.14"
  }
}
